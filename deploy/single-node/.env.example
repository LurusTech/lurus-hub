# ─── Required: Database ─────────────────────────────────────────────────────
# Pick a strong password. The PG container creates user `lurus` with this on
# first boot; changing it later requires entering the container.
POSTGRES_PASSWORD=ReplaceWithStrongPassword
POSTGRES_DB=lurus_hub

# ─── Required: Session ─────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
SESSION_SECRET=ReplaceWithBase64Secret

# ─── Required: Zitadel (reuse production auth at auth.lurus.cn) ────────────
ZITADEL_ENABLED=true
ZITADEL_FALLBACK_TO_LEGACY=true

ZITADEL_ISSUER=https://auth.lurus.cn
ZITADEL_CLIENT_ID=YOUR_CLIENT_ID@lurus-hub
ZITADEL_CLIENT_SECRET=YOUR_CLIENT_SECRET

# IMPORTANT: register this exact URL as a Redirect URI in the Zitadel console
# for the client above. Replace 10.0.0.42:3000 with your server IP and port.
ZITADEL_REDIRECT_URI=http://10.0.0.42:3000/api/v2/oauth/callback
ZITADEL_POST_LOGOUT_REDIRECT_URI=http://10.0.0.42:3000/logout

ZITADEL_JWKS_URI=https://auth.lurus.cn/oauth/v2/keys
ZITADEL_AUTHORIZATION_ENDPOINT=https://auth.lurus.cn/oauth/v2/authorize
ZITADEL_TOKEN_ENDPOINT=https://auth.lurus.cn/oauth/v2/token
ZITADEL_USERINFO_ENDPOINT=https://auth.lurus.cn/oidc/v1/userinfo
ZITADEL_END_SESSION_ENDPOINT=https://auth.lurus.cn/oidc/v1/end_session
ZITADEL_INTROSPECTION_ENDPOINT=https://auth.lurus.cn/oauth/v2/introspect

ZITADEL_DEFAULT_ORG_ID=YOUR_ORG_ID
ZITADEL_DEFAULT_ORG_NAME=Lurus Platform
ZITADEL_DEFAULT_ORG_DOMAIN=lurus
ZITADEL_OAUTH_SCOPES=openid email profile offline_access

# ─── Optional ──────────────────────────────────────────────────────────────
TZ=Asia/Shanghai
PUBLIC_PORT=3000
